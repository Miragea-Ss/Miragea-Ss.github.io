---
import type { AtelierLang } from '../data/atelier-copy';

interface Props {
  title: string;
  description: string;
  lang: AtelierLang;
}

const { title, description, lang } = Astro.props;

const htmlLang = lang === 'zh' ? 'zh' : lang === 'ja' ? 'ja' : 'en';

const fontHref =
  lang === 'ja'
    ? 'https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=Noto+Serif+JP:wght@400;600;700&family=Playfair+Display:wght@500;700&display=swap'
    : lang === 'zh'
      ? 'https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=Noto+Serif+SC:wght@400;600;700&family=Playfair+Display:wght@500;700&display=swap'
      : 'https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=Playfair+Display:ital,wght@0,500;0,700;1,500&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&display=swap';
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={fontHref} rel="stylesheet" />
    <link rel="stylesheet" href="/assets/brand/brand-glow.css" />
    <link rel="stylesheet" href="/eliora/atelier/assets/css/atelier.css" />
  </head>
  <body>
    <slot />
    <script is:inline src="/eliora/atelier/assets/js/site.js"></script>
  </body>
</html>