---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Miragea">
  <!-- 全体を包むコンテナ（画面いっぱいの高さ） -->
  <main class="relative w-full h-screen overflow-hidden bg-black">
    
    <!-- === 背景動画レイヤー (最背面) === -->
    <video
      class="absolute top-0 left-0 w-full h-full object-cover opacity-80 z-0"
      autoplay
      loop
      muted
      playsinline
      src="https://gateway.pinata.cloud/ipfs/bafybeibdmddowvckm7a5ss4gcnwu75boggasgyrm3agjipm5z5xdxzdez4"
    >
    </video>

    <!-- === 暗幕レイヤー (文字を読みやすくするための薄い黒) === -->
    <div class="absolute inset-0 bg-black/30 z-10"></div>

    <!-- === 前面のコンテンツ (文字など) === -->
    <div class="relative z-20 flex flex-col items-center justify-center h-full text-center">
      <!-- MIRAGEA タイトル -->
      <h1 class="text-6xl md:text-9xl font-thin tracking-[0.2em] text-white animate-pulse mix-blend-overlay">
        MIRAGEA
      </h1>
      
      <!-- サブタイトル -->
      <p class="mt-6 text-gray-300 font-mono text-xs md:text-sm tracking-widest uppercase opacity-80">
        Archive of Sensory Processing Sensitivity
      </p>

      <!-- 入室ボタン（装飾） -->
      <div class="mt-12">
        <span class="inline-block px-8 py-2 border border-white/20 rounded-full text-white/60 text-xs tracking-widest hover:bg-white/10 transition-all cursor-pointer">
          ENTER THE VOID
        </span>
      </div>
    </div>

  </main>
</Layout>