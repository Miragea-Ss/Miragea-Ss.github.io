---
import Layout from '../../../../site-layouts/Layout.astro';

/** 投稿后填入 BV 号即可嵌入 */
const EP02_BVID = '';
const SPACE = 'https://space.bilibili.com/1321407655';
const playerSrc = EP02_BVID
  ? `//player.bilibili.com/player.html?bvid=${EP02_BVID}&page=1&high_quality=1&danmaku=0`
  : '';
---

<Layout title="EP02 · 榨干 Grok 4.5 | 极客魔咒" lang="zh">
  <main class="gs-ep-page">
    <div class="gs-wrap">
      <p class="gs-crumb">
        <a href="/zh/">档案</a> · <a href="/zh/geekspell/">极客魔咒</a> · EP02
      </p>
      <p class="gs-eyebrow">极客魔咒科普 EP02</p>
      <h1>榨干 Grok 4.5：强在哪？怎么用？</h1>
      <p class="gs-lead">
        你是谁、强在哪里、怎样配合才能真正交付。四个强项 + 五个习惯 + 可复制开场模板。
      </p>

      {
        playerSrc ? (
          <div class="gs-player">
            <iframe
              src={playerSrc}
              scrolling="no"
              border="0"
              frameborder="no"
              framespacing="0"
              allowfullscreen="true"
              title="极客魔咒 EP02 B站播放"
            />
          </div>
        ) : (
          <div class="gs-player-fallback">
            <p>在 B站观看完整版动画（约 3 分钟）</p>
            <a class="gs-btn" href={SPACE} target="_blank" rel="noopener">
              打开 极客魔咒工作室 空间 →
            </a>
            <p class="gs-note">
              上传后把本页 <code>EP02_BVID</code> 改成 BV 号即可嵌入。
            </p>
          </div>
        )
      }

      <section class="gs-body">
        <h2>本集要点</h2>
        <ul>
          <li>工程落地：进项目结构读改，对约束负责。</li>
          <li>表达结构：拆步骤、列重点、可复制方案。</li>
          <li>工具协同：搜索到交付串成工作流。</li>
          <li>品牌审美：跟着你的世界观与禁止项走。</li>
          <li>五个习惯：目标、范围、约束、上下文、分阶段验收。</li>
        </ul>

        <h2>建议标题 / 简介</h2>
        <pre class="gs-desc">榨干 Grok 4.5：最新xAI Grok 4.5 强在哪？怎么用？｜极客魔咒科普 EP02

极客魔咒科普 EP02｜3分钟搞懂 Grok 4.5。
四个强项 · 五个习惯 · 从能聊升级到能交付。

#Grok #xAI #AI编程 #提示词 #极客魔咒</pre>

        <p class="gs-links">
          <a href="/zh/geekspell/">← 工作室首页</a>
          ·
          <a href="/zh/geekspell/ep01-codex-language/">上一集 EP01</a>
          ·
          <a href={SPACE} target="_blank" rel="noopener">B站空间</a>
        </p>
      </section>
    </div>
  </main>
</Layout>

<style is:global>
  .gs-ep-page {
    min-height: 100vh;
    color: #e8ecf8;
    background: linear-gradient(180deg, #1a1a3e 0%, #0a0a0f 50%, #050508 100%);
    font-family: system-ui, 'Noto Sans SC', sans-serif;
  }
  .gs-wrap {
    max-width: 900px;
    margin: 0 auto;
    padding: 5.5rem 1.5rem 4rem;
  }
  .gs-crumb {
    font-size: 0.8rem;
    color: rgba(200, 208, 224, 0.55);
    margin-bottom: 1rem;
  }
  .gs-crumb a {
    color: #c9a962;
    text-decoration: none;
  }
  .gs-eyebrow {
    font-family: ui-monospace, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    color: #5b9cff;
    margin-bottom: 0.75rem;
  }
  .gs-ep-page h1 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    line-height: 1.3;
    margin-bottom: 1rem;
  }
  .gs-lead {
    color: rgba(200, 208, 224, 0.7);
    line-height: 1.8;
    margin-bottom: 2rem;
    max-width: 40rem;
  }
  .gs-player {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(201, 169, 98, 0.25);
    background: #000;
  }
  .gs-player iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .gs-player-fallback {
    border-radius: 12px;
    border: 1px solid rgba(201, 169, 98, 0.25);
    background: rgba(0, 0, 0, 0.45);
    padding: 2rem;
    text-align: center;
  }
  .gs-btn {
    display: inline-flex;
    margin-top: 1rem;
    min-height: 2.75rem;
    padding: 0 1.25rem;
    align-items: center;
    border-radius: 8px;
    background: #f5f5f4;
    color: #0a0a0f;
    font-weight: 600;
    text-decoration: none;
  }
  .gs-note {
    margin-top: 1rem;
    font-size: 0.8rem;
    color: rgba(200, 208, 224, 0.45);
  }
  .gs-note code {
    color: #c9a962;
  }
  .gs-body {
    margin-top: 2.5rem;
  }
  .gs-body h2 {
    font-size: 1.25rem;
    margin: 1.75rem 0 0.75rem;
    color: #c9a962;
  }
  .gs-body ul {
    padding-left: 1.25rem;
    line-height: 1.85;
    color: rgba(200, 208, 224, 0.75);
  }
  .gs-desc {
    margin-top: 0.75rem;
    padding: 1rem 1.15rem;
    border-radius: 10px;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.85rem;
    line-height: 1.7;
    white-space: pre-wrap;
    color: #c8d0e0;
  }
  .gs-links {
    margin-top: 2rem;
    font-size: 0.9rem;
  }
  .gs-links a {
    color: #fecdd3;
    text-decoration: none;
  }
</style>
