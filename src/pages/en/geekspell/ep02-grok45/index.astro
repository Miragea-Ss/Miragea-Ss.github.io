---
import Layout from '../../../../site-layouts/Layout.astro';
import GeekSpellBaseStyles from '../../../../components/geekspell/GeekSpellBaseStyles.astro';

/** YouTube video id — English EP02 */
const YT_ID = 'jnGfZdlX6aI';
const YT_WATCH = `https://youtu.be/${YT_ID}`;
const YT_EMBED = `https://www.youtube.com/embed/${YT_ID}`;
const YT_JA = 'https://youtu.be/JXhmRa7r6u8';
---

<Layout title="EP02 · Grok 4.5 Intro | GeekSpell" lang="en">
  <GeekSpellBaseStyles />
  <main class="gs-ep-page">
    <div class="gs-wrap">
      <p class="gs-crumb">
        <a href="/en/">Archive</a> · <a href="/en/geekspell/">GeekSpell</a> · EP02
      </p>
      <p class="gs-eyebrow">GeekSpell literacy EP02 · English</p>
      <h1>Grok 4.5 — the useful cut</h1>
      <p class="gs-lead">
        What it is, what it’s good at, and how to prompt it so you unlock real performance — four
        strengths, five habits, and a copy-ready opener.
      </p>

      <div class="gs-player">
        <iframe
          src={YT_EMBED}
          title="GeekSpell EP02 Grok 4.5 — English"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          loading="lazy"
          referrerpolicy="strict-origin-when-cross-origin"
        />
      </div>
      <a class="gs-yt-link" href={YT_WATCH} target="_blank" rel="noopener">Open on YouTube ↗</a>

      <section class="gs-body">
        <h2>What you’ll learn</h2>
        <ul>
          <li>Ship in the real repo — structure, read, edit, respect constraints.</li>
          <li>Clear structure — steps, priorities, copy-ready plans.</li>
          <li>Tool teamwork — search → docs → media as one workflow.</li>
          <li>Brand and taste — follow your worldview and hard no’s.</li>
          <li>Five habits — goal, scope, constraints, context, staged review.</li>
        </ul>

        <h2>Watch also</h2>
        <pre class="gs-desc">English (this page): {YT_WATCH}
Japanese: {YT_JA}
Chinese series hub: https://miragea-ss.github.io/zh/geekspell/

#Grok #Grok45 #xAI #PromptEngineering #GeekSpell</pre>

        <p class="gs-links">
          <a href="/en/geekspell/">← Studio home</a>
          ·
          <a href="/ja/geekspell/ep02-grok45/">Japanese EP02</a>
          ·
          <a href="/zh/geekspell/ep02-grok45/">Chinese EP02</a>
          ·
          <a href={YT_WATCH} target="_blank" rel="noopener">YouTube</a>
        </p>
      </section>
    </div>
  </main>
</Layout>
