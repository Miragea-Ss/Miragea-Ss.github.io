---
import Layout from '../../../../site-layouts/Layout.astro';
import GeekSpellBaseStyles from '../../../../components/geekspell/GeekSpellBaseStyles.astro';

const YT_ID = 'lrjdhYpkUxk';
const YT_EMBED = `https://www.youtube.com/embed/${YT_ID}`;
const YT_WATCH = `https://youtu.be/${YT_ID}`;
---

<Layout title="EP06 · How one person runs an agent team | GeekSpell" lang="en">
  <GeekSpellBaseStyles />
  <main class="gs-ep-page">
    <div class="gs-wrap">
      <p class="gs-crumb">
        <a href="/en/">Archive</a> · <a href="/en/geekspell/">GeekSpell</a> · EP06
      </p>
      <p class="gs-eyebrow">GeekSpell literacy EP06 · English · Agent team</p>
      <h1>How one person runs an agent team</h1>
      <p class="gs-lead">
        Stop treating one agent as an all-purpose employee. Complex work needs roles, boundaries,
        checkpoints, and recovery — a work system, not a chat box.
      </p>
      <div class="gs-player">
        <iframe
          src={YT_EMBED}
          title="GeekSpell EP06 EN"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          loading="lazy"
        />
      </div>
      <p class="gs-links">
        <a href="/en/geekspell/ep05-acceptance-loop/">← EP05 Acceptance</a>
        ·
        <a href="/en/geekspell/ep07-skill-workflow/">EP07 Skill &amp; Workflow →</a>
        ·
        <a href="/zh/geekspell/ep06-agent-team/">中文 EP06</a>
        ·
        <a href="/ja/geekspell/ep06-agent-team/">日本語 EP06</a>
        ·
        <a href={YT_WATCH} target="_blank" rel="noopener">YouTube</a>
      </p>
      <section class="gs-body">
        <h2>What you will learn (step by step)</h2>
        <ul>
          <li>Why one agent collapses on multi-skill work</li>
          <li>Seven roles: Manager, Research, Design, Coding, Testing, Documentation, Auditor</li>
          <li>You set goals and boundaries; the Manager orchestrates</li>
          <li>Real supervision: permissions, logs, checkpoints, rollback, sandbox, budget, data walls, acceptance</li>
          <li>You run a verifiable work system — not a chatbot</li>
        </ul>
        <h2>Series path</h2>
        <p>
          EP03 command · EP04 scope · EP05 acceptance · <strong>EP06 team</strong> · EP07 tools &amp;
          pipelines.
        </p>
      </section>
    </div>
  </main>
</Layout>
