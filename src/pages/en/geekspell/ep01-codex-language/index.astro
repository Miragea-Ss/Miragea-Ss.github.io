---
import Layout from '../../../../site-layouts/Layout.astro';
import GeekSpellBaseStyles from '../../../../components/geekspell/GeekSpellBaseStyles.astro';

/** Paste YouTube id after upload */
const YT_ID = '';
const YT_WATCH = YT_ID ? `https://youtu.be/${YT_ID}` : '';
const YT_EMBED = YT_ID ? `https://www.youtube.com/embed/${YT_ID}` : '';
const BILI = 'https://www.bilibili.com/video/BV1psMj6zEv7/';
const LOCAL_HINT = 'H:/Grok/geekspell-ep01-youtube-2026-07-11/youtube-ready/GeekSpell-EP01-Codex-Language-EN-YouTube.mp4';
---

<Layout title="EP01 · Codex Prompt Language | GeekSpell" lang="en">
  <GeekSpellBaseStyles />
  <main class="gs-ep-page">
    <div class="gs-wrap">
      <p class="gs-crumb">
        <a href="/en/">Archive</a> · <a href="/en/geekspell/">GeekSpell</a> · EP01
      </p>
      <p class="gs-eyebrow">GeekSpell literacy EP01 · English</p>
      <h1>Codex: which language when you prompt?</h1>
      <p class="gs-lead">
        English for code stability, local language for taste — and a fixed template you can reuse every time.
      </p>

      {
        YT_EMBED ? (
          <div class="gs-player">
            <iframe
              src={YT_EMBED}
              title="GeekSpell EP01 Codex language — English"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              loading="lazy"
            />
          </div>
        ) : (
          <div class="gs-player-fallback">
            <p>YouTube file ready locally — set <code>YT_ID</code> after upload.</p>
            <p class="gs-note mono">{LOCAL_HINT}</p>
            <a class="gs-btn" href={BILI} target="_blank" rel="noopener">Chinese version on Bilibili →</a>
          </div>
        )
      }
      {YT_WATCH && <a class="gs-yt-link" href={YT_WATCH} target="_blank" rel="noopener">Open on YouTube ↗</a>}

      <section class="gs-body">
        <h2>What you’ll learn</h2>
        <ul>
          <li>Why English is the most stable for Codex coding tasks.</li>
          <li>When Chinese ecosystem research should stay in Chinese.</li>
          <li>Strongest combo: EN specs + your language for brand taste.</li>
          <li>Weak vs strong prompts + Role / Task / Do not / Acceptance.</li>
        </ul>
        <p class="gs-links">
          <a href="/en/geekspell/">← Studio home</a>
          ·
          <a href="/en/geekspell/ep02-grok45/">EP02 Grok 4.5 →</a>
          ·
          <a href="/ja/geekspell/ep01-codex-language/">Japanese EP01</a>
          ·
          <a href="/zh/geekspell/ep01-codex-language/">Chinese EP01</a>
        </p>
      </section>
    </div>
  </main>
</Layout>

<style is:global>
  .gs-player-fallback {
    border-radius: 12px;
    border: 1px solid rgba(201, 169, 98, 0.25);
    background: rgba(0, 0, 0, 0.45);
    padding: 2rem;
    text-align: center;
  }
  .gs-player-fallback .gs-btn {
    display: inline-flex;
    margin-top: 1rem;
    min-height: 2.75rem;
    padding: 0 1.25rem;
    align-items: center;
    border-radius: 8px;
    background: #f5f5f4;
    color: #0a0a0f;
    font-weight: 600;
    text-decoration: none;
  }
  .gs-note.mono {
    margin-top: 0.75rem;
    font-family: ui-monospace, monospace;
    font-size: 0.75rem;
    color: rgba(200, 208, 224, 0.45);
    word-break: break-all;
  }
</style>
