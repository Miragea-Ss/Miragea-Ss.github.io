---
import Layout from '../../../../site-layouts/Layout.astro';
import GeekSpellBaseStyles from '../../../../components/geekspell/GeekSpellBaseStyles.astro';

const YT_ID = 'neylQ_ykdLI';
const YT_EMBED = `https://www.youtube.com/embed/${YT_ID}`;
const YT_WATCH = `https://youtu.be/${YT_ID}`;
---

<Layout title="EP07 · Agent・Skill・Workflow の違い | ギークスペル" lang="ja">
  <GeekSpellBaseStyles />
  <main class="gs-ep-page">
    <div class="gs-wrap">
      <p class="gs-crumb">
        <a href="/ja/">アーカイブ</a> · <a href="/ja/geekspell/">ギークスペル</a> · EP07
      </p>
      <p class="gs-eyebrow">ギークスペル リテラシー EP07 · 日本語 · Skill と Workflow</p>
      <h1>Agent・Skill・Workflow の違い</h1>
      <p class="gs-lead">
        「Agent を呼ぶ」だけでは足りない。作業者・道具・流水線を分けて、初めて効率よく、安全に使える。
      </p>
      <div class="gs-player">
        <iframe
          src={YT_EMBED}
          title="ギークスペル EP07 JA"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          loading="lazy"
        />
      </div>
      <p class="gs-links">
        <a href="/ja/geekspell/ep06-agent-team/">← EP06 Agent チーム</a>
        ·
        <a href="/zh/geekspell/ep07-skill-workflow/">中文 EP07</a>
        ·
        <a href="/en/geekspell/ep07-skill-workflow/">English EP07</a>
        ·
        <a href={YT_WATCH} target="_blank" rel="noopener">YouTube</a>
      </p>
      <section class="gs-body">
        <h2>学ぶこと（Step by step）</h2>
        <ul>
          <li>
            <strong>Agent</strong> = 目標と権限の下で動く作業者
          </li>
          <li>
            <strong>Skill</strong> = 入力→出力が明確な再利用ツール
          </li>
          <li>
            <strong>Workflow</strong> = Skill を並べた流水線と検収
          </li>
          <li>先に Skill、次に Workflow、最後に Agent へ渡す</li>
          <li>五欄テンプレを埋めてから会話を始める</li>
        </ul>
        <h2>シリーズの位置</h2>
        <p>
          EP03 指令 → EP04 範囲 → EP06 チーム → <strong>EP07 道具と流水線</strong> → EP08
          一枚クローズドループ。
        </p>
      </section>
    </div>
  </main>
</Layout>
