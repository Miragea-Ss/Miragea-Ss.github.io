---
import Layout from '../../site-layouts/Layout.astro';
import MirageArchiveHome from '../../components/MirageArchiveHome.astro';
import { getCollection } from 'astro:content';

const allThoughts = (await getCollection('thoughts')).sort(
  (a, b) => b.data.intuitionDate.valueOf() - a.data.intuitionDate.valueOf()
);
---

<Layout title="Miragea | 感覚アーカイブ" lang="ja">
  <MirageArchiveHome thoughts={allThoughts} lang="ja" />
</Layout>
