const exItems = [
  ['Extreme', 'High-intensity perception.'],
  ['Experience', 'Body, memory, and emotion.'],
  ['Execution', 'Turning sensitivity into work.'],
  ['Example', 'Making invisible patterns visible.'],
  ['Exchange', 'Community, service, dialogue.'],
  ['Excitation', 'Energy, signal, and resonance.'],
  ['Extra', 'The surplus that becomes style.'],
  ['Express', 'The final visible form.'],
];

---

<main class="min-h-screen bg-[#050505] text-[#f7f2ea]">
  <section class="relative overflow-hidden px-6 pb-16 pt-28 md:px-12">
    <div class="absolute inset-0 opacity-80 [background-image:linear-gradient(rgba(255,255,255,.025)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.025)_1px,transparent_1px),linear-gradient(125deg,rgba(240,123,154,.17),transparent_32%),linear-gradient(245deg,rgba(116,216,231,.12),transparent_38%)] [background-size:38px_38px,38px_38px,auto,auto]"></div>
    <div class="relative mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-[1fr_420px]">
      <div>
        <div class="mb-6 inline-flex items-center gap-3 text-xs uppercase tracking-[0.18em] text-stone-400">
          <span class="h-2 w-2 rounded-full bg-rose-400 shadow-[0_0_18px_rgba(251,113,133,.85)]"></span>
          {copy.eyebrow}
        </div>
        <h1 class="max-w-4xl text-5xl font-extralight leading-[0.94] tracking-normal md:text-8xl">
          {copy.heroTitle}
        </h1>
        <p class="mt-7 max-w-3xl text-lg leading-8 text-stone-400 md:text-xl">
          {copy.heroLead}
        </p>
        <p class="mt-5 max-w-3xl leading-8 text-stone-300">
          {copy.heroNote}
        </p>
        <div class="mt-9 flex flex-wrap gap-3">
          <!-- 修正①: hrefを /eliora/ から /eliora/index.html に変更 -->
          <a class="inline-flex min-h-12 items-center justify-center rounded-lg bg-stone-100 px-5 font-bold text-black transition hover:bg-rose-200" href="/eliora/index.html">
            {copy.enterEliora}
          </a>
          <a class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white/15 px-5 font-bold text-stone-100 transition hover:border-white/35" href="https://x.com/Miragea_S/">
            {copy.followX}
          </a>
          <a class="inline-flex min-h-12 items-center justify-center rounded-lg border border-white/15 px-5 font-bold text-stone-100 transition hover:border-white/35" href="https://a4977a63.pinit.eth.limo/">
            {copy.ipfsMirror}
          </a>
        </div>
      </div>

      <aside class="overflow-hidden rounded-lg border border-white/15 bg-black/55">
        <img
          class="aspect-video w-full object-cover"
          src="https://pbs.twimg.com/profile_banners/1384657958613635074/1714738084"
          alt="Miragea visual banner"
        />
        <div class="grid grid-cols-[76px_1fr] items-center gap-4 p-5">
          <img
            class="h-[76px] w-[76px] rounded-lg border border-white/15 object-cover"
            src="https://pbs.twimg.com/profile_images/1786367070315454464/p40uTio3_200x200.jpg"
            alt="Miragea profile image"
          />
          <div>
            <strong class="block text-xl text-stone-100">EX_Her / Miragea</strong>
            <span class="mt-1 block leading-7 text-stone-400">
              Art, visuals, words, HSP perception, nervous-system domino dissection.
            </span>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="px-6 py-20 md:px-12">
    <div class="mx-auto max-w-7xl">
      <div class="mb-8 flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
        <h2 class="text-4xl font-light tracking-normal md:text-6xl">{copy.identityTitle}</h2>
        <p class="max-w-xl leading-8 text-stone-400">
          {copy.identityCopy}
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        <article class="rounded-lg border border-white/15 bg-white/[.055] p-6">
          <span class="mb-5 inline-flex rounded-full border border-white/15 px-3 py-1 text-xs text-stone-400">Visual</span>
          <b class="mb-3 block text-xl">{copy.visualTitle}</b>
          <p class="leading-8 text-stone-400">{copy.visualCopy}</p>
        </article>
        <article class="rounded-lg border border-white/15 bg-white/[.055] p-6">
          <span class="mb-5 inline-flex rounded-full border border-white/15 px-3 py-1 text-xs text-stone-400">Words</span>
          <b class="mb-3 block text-xl">{copy.wordsTitle}</b>
          <p class="leading-8 text-stone-400">{copy.wordsCopy}</p>
        </article>
        <article class="rounded-lg border border-white/15 bg-white/[.055] p-6">
          <span class="mb-5 inline-flex rounded-full border border-white/15 px-3 py-1 text-xs text-stone-400">HSP</span>
          <b class="mb-3 block text-xl">{copy.hspTitle}</b>
          <p class="leading-8 text-stone-400">{copy.hspCopy}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="px-6 py-20 md:px-12">
    <div class="mx-auto max-w-7xl">
      <div class="mb-8 flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
        <h2 class="text-4xl font-light tracking-normal md:text-6xl">{copy.exTitle}</h2>
        <p class="max-w-xl leading-8 text-stone-400">
          {copy.exCopy}
        </p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {exItems.map(([title, copy]) => (
          <div class="min-h-28 rounded-lg border border-white/15 bg-white/[.045] p-5">
            <strong class="mb-2 block text-lg">{title}</strong>
            <span class="text-sm leading-6 text-stone-400">{copy}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="px-6 py-20 md:px-12">
    <div class="mx-auto max-w-7xl">
      <div class="mb-8 flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
        <h2 class="text-4xl font-light tracking-normal md:text-6xl">{copy.routesTitle}</h2>
        <p class="max-w-xl leading-8 text-stone-400">
          {copy.routesCopy}
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        <article class="rounded-lg border border-white/15 bg-black/55 p-6">
          <span class="mb-4 block text-xs uppercase tracking-[0.16em] text-yellow-300">Layer 1</span>
          <h3 class="mb-3 text-2xl">{copy.githubLayer}</h3>
          <p class="mb-5 leading-8 text-stone-400">{copy.githubCopy}</p>
          <!-- 改善①: 言語（lang）に応じて、該当言語のアーカイブに飛べるように動的URLに変更 -->
          <a class="font-bold" href={`https://miragea-ss.github.io/${lang}/`}>{copy.openArchive}</a>
        </article>
        <article class="rounded-lg border border-white/15 bg-black/55 p-6">
          <span class="mb-4 block text-xs uppercase tracking-[0.16em] text-yellow-300">Mirror</span>
          <h3 class="mb-3 text-2xl">IPFS</h3>
          <p class="mb-5 leading-8 text-stone-400">{copy.ipfsCopy}</p>
          <a class="font-bold" href="https://a4977a63.pinit.eth.limo/">{copy.openIpfs}</a>
        </article>
        <article class="rounded-lg border border-white/15 bg-black/55 p-6">
          <span class="mb-4 block text-xs uppercase tracking-[0.16em] text-yellow-300">Layer 2</span>
          <h3 class="mb-3 text-2xl">Eliora</h3>
          <p class="mb-5 leading-8 text-stone-400">{copy.elioraCopy}</p>
          <!-- 修正②: hrefを /eliora/ から /eliora/index.html に変更 -->
          <a class="font-bold" href="/eliora/index.html">{copy.enterEliora}</a>
        </article>
      </div>
    </div>
  </section>

  <section class="px-6 py-20 md:px-12">
    <div class="mx-auto max-w-7xl">
      <div class="mb-10 text-center">
        <h2 class="text-4xl font-light tracking-normal md:text-6xl">{copy.recordsTitle}</h2>
        <p class="mx-auto mt-5 max-w-2xl leading-8 text-stone-400">
          {copy.recordsCopy}
        </p>
      </div>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {thoughts.map((post) => (
          <ThoughtCard post={post} />
        ))}
      </div>
    </div>
  </section>
</main>

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Miragea',
  alternateName: 'EX_Her',
  // 改善②: SEOメタデータ用のURLも言語に応じて動的に変化するように変更
  url: `https://miragea-ss.github.io/${lang}/`,
  sameAs: [
    'https://x.com/Miragea_S/',
    'https://a4977a63.pinit.eth.limo/',
    '/eliora/index.html', // 修正③: ここも /eliora/index.html に統一
  ],
  knowsAbout: [
    'Art',
    'Visuals',
    'Words',
    'HSP',
    '3DCG',
    'AI Services',
    'Digital Products',
    'Data Sovereignty',
  ],
})} />