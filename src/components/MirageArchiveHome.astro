---
import ThoughtCard from './ThoughtCard.astro';
import AtelierAgentStrip from './AtelierAgentStrip.astro';
import type { CollectionEntry } from 'astro:content';
import { getExCards, videoWorks } from '../data/ex-system';

interface Props {
  thoughts: CollectionEntry<'thoughts'>[];
  lang?: 'en' | 'ja' | 'zh';
