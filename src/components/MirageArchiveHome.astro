    enterpriseContact: '项目咨询',
    enterEliora: 'Eliora 工作室',
    enterAtelier: '宇宙 AI 工坊',
    routeArchive: '档案',
    routeStudio: 'Eliora 工作室',
    routeAtelier: '工坊',
