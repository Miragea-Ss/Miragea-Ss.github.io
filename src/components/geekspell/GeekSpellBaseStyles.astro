---
/** Shared visual language for GeekSpell Studio pages (EN / JA / ZH). */
---
<style is:global>
  .gs-page {
    --obsidian: #0a0a0f;
    --indigo: #1a1a3e;
    --spell-gold: #c9a962;
    --signal-cyan: #5b9cff;
    --spell-violet: #8b5cf6;
    --text: #e8ecf8;
    --muted: rgba(200, 208, 224, 0.65);
    --panel: rgba(10, 12, 22, 0.72);
    min-height: 100vh;
    color: var(--text);
    font-family: 'IBM Plex Sans', 'Noto Sans JP', 'Noto Sans SC', system-ui, sans-serif;
    background:
      radial-gradient(ellipse 100% 60% at 50% -10%, rgba(139, 92, 246, 0.18) 0%, transparent 55%),
      radial-gradient(ellipse 80% 50% at 80% 20%, rgba(91, 156, 255, 0.12) 0%, transparent 50%),
      linear-gradient(180deg, var(--indigo) 0%, var(--obsidian) 45%, #050508 100%);
  }
  .gs-stars {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.45;
    background-image:
      radial-gradient(1px 1px at 12% 18%, #fff, transparent),
      radial-gradient(1px 1px at 72% 32%, #fff, transparent),
      radial-gradient(1.5px 1.5px at 48% 68%, #c9d4ff, transparent);
  }
  .gs-wrap {
    position: relative;
    z-index: 1;
    max-width: 1120px;
    margin: 0 auto;
    padding: 5.5rem 1.5rem 4rem;
  }
  .gs-topbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 3rem;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .gs-topbar a {
    color: var(--spell-gold);
    text-decoration: none;
  }
  .gs-topbar a:hover {
    color: #f0d9a0;
  }
  .gs-hero {
    display: grid;
    gap: 2.5rem;
    margin-bottom: 4rem;
  }
  @media (min-width: 768px) {
    .gs-hero {
      grid-template-columns: 1.15fr 0.85fr;
      align-items: end;
    }
  }
  .gs-eyebrow {
    font-family: ui-monospace, 'IBM Plex Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--signal-cyan);
    margin-bottom: 1rem;
  }
  .gs-hero h1 {
    font-family: Georgia, 'Noto Serif JP', 'Noto Serif SC', serif;
    font-weight: 600;
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }
  .gs-hero h1 em {
    font-style: italic;
    color: var(--spell-gold);
  }
  .gs-sub-en {
    font-family: ui-monospace, monospace;
    font-size: 0.85rem;
    color: var(--spell-violet);
    margin-bottom: 1.25rem;
  }
  .gs-lead {
    max-width: 36rem;
    line-height: 1.85;
    color: var(--muted);
    font-size: 1.05rem;
  }
  .gs-tag {
    margin-top: 1.5rem;
    padding-left: 1rem;
    border-left: 2px solid rgba(201, 169, 98, 0.5);
    font-style: italic;
    color: rgba(232, 236, 248, 0.85);
  }
  .gs-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }
  .gs-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0 1.25rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
  }
  .gs-btn-primary {
    background: #f5f5f4;
    color: #0a0a0f;
  }
  .gs-btn-primary:hover {
    background: #fecdd3;
  }
  .gs-btn-ghost {
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: var(--text);
  }
  .gs-btn-ghost:hover {
    border-color: rgba(139, 92, 246, 0.5);
  }
  .gs-panel {
    border-radius: 20px;
    border: 1px solid rgba(201, 169, 98, 0.28);
    background: var(--panel);
    backdrop-filter: blur(12px);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.45);
    padding: 1.5rem;
  }
  .gs-panel-label {
    font-family: ui-monospace, monospace;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: var(--spell-gold);
    margin-bottom: 1rem;
  }
  .gs-spell {
    font-family: ui-monospace, monospace;
    font-size: 0.78rem;
    line-height: 1.7;
    color: #b8c8e8;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .gs-spell .kw {
    color: var(--signal-cyan);
  }
  .gs-spell .cm {
    color: rgba(200, 208, 224, 0.4);
  }
  .gs-spell .zh {
    color: #ffd166;
  }
  .gs-section-head {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin: 3rem 0 1.5rem;
  }
  .gs-section-head h2 {
    font-family: Georgia, serif;
    font-weight: 400;
    font-size: clamp(1.8rem, 4vw, 2.4rem);
  }
  .gs-section-head p {
    max-width: 28rem;
    line-height: 1.75;
    color: var(--muted);
    font-size: 0.95rem;
  }
  .gs-grid3 {
    display: grid;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .gs-grid3 {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .gs-card {
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(0, 0, 0, 0.45);
    padding: 1.25rem;
  }
  .gs-kicker {
    font-family: ui-monospace, monospace;
    font-size: 0.65rem;
    letter-spacing: 0.16em;
    color: #a5f3fc;
    margin-bottom: 0.75rem;
  }
  .gs-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }
  .gs-card p {
    font-size: 0.88rem;
    line-height: 1.65;
    color: var(--muted);
  }
  .gs-ep-list {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }
  .gs-ep {
    display: grid;
    gap: 1rem;
    border-radius: 12px;
    border: 1px solid rgba(201, 169, 98, 0.2);
    background: rgba(0, 0, 0, 0.5);
    padding: 1.25rem 1.5rem;
  }
  @media (min-width: 640px) {
    .gs-ep {
      grid-template-columns: auto 1fr auto;
      align-items: center;
    }
  }
  .gs-ep-num {
    font-family: ui-monospace, monospace;
    font-size: 0.75rem;
    color: var(--spell-gold);
    letter-spacing: 0.12em;
  }
  .gs-ep h4 {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }
  .gs-ep p {
    font-size: 0.85rem;
    color: var(--muted);
  }
  .gs-ep a {
    font-weight: 600;
    font-size: 0.85rem;
    color: #fecdd3;
    text-decoration: none;
  }
  .gs-lineage {
    margin-top: 4rem;
    padding: 2rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: linear-gradient(145deg, rgba(26, 26, 62, 0.6), rgba(10, 10, 15, 0.8));
  }
  .gs-lineage h3 {
    font-family: Georgia, serif;
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }
  .gs-lineage-copy {
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 1rem;
    max-width: 40rem;
  }
  .gs-flow {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    font-family: ui-monospace, monospace;
    font-size: 0.8rem;
    color: var(--muted);
  }
  .gs-flow .arrow {
    color: var(--spell-violet);
  }
  .gs-foot {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.75rem;
    color: rgba(200, 208, 224, 0.4);
  }
  .gs-foot a {
    color: var(--spell-gold);
  }

  /* Episode page */
  .gs-ep-page {
    min-height: 100vh;
    color: #e8ecf8;
    background: linear-gradient(180deg, #1a1a3e 0%, #0a0a0f 50%, #050508 100%);
    font-family: system-ui, 'Noto Sans JP', 'Noto Sans SC', sans-serif;
  }
  .gs-ep-page .gs-wrap {
    max-width: 900px;
  }
  .gs-crumb {
    font-size: 0.8rem;
    color: rgba(200, 208, 224, 0.55);
    margin-bottom: 1rem;
  }
  .gs-crumb a {
    color: #c9a962;
    text-decoration: none;
  }
  .gs-ep-page h1 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    line-height: 1.3;
    margin-bottom: 1rem;
  }
  .gs-ep-page .gs-lead {
    color: rgba(200, 208, 224, 0.7);
    line-height: 1.8;
    margin-bottom: 2rem;
    max-width: 40rem;
  }
  .gs-player {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(201, 169, 98, 0.25);
    background: #000;
  }
  .gs-player iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .gs-body {
    margin-top: 2.5rem;
  }
  .gs-body h2 {
    font-size: 1.25rem;
    margin: 1.75rem 0 0.75rem;
    color: #c9a962;
  }
  .gs-body ul {
    padding-left: 1.25rem;
    line-height: 1.85;
    color: rgba(200, 208, 224, 0.75);
  }
  .gs-desc {
    margin-top: 0.75rem;
    padding: 1rem 1.15rem;
    border-radius: 10px;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.85rem;
    line-height: 1.7;
    white-space: pre-wrap;
    color: #c8d0e0;
  }
  .gs-links {
    margin-top: 2rem;
    font-size: 0.9rem;
  }
  .gs-links a {
    color: #fecdd3;
    text-decoration: none;
  }
  .gs-yt-link {
    display: inline-flex;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--spell-gold);
  }
</style>
