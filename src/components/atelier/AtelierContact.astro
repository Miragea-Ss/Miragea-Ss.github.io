---
import type { AtelierLang } from '../../data/atelier-copy';
import { atelierHomeCopy } from '../../data/atelier-copy';
import type { ContactCopy } from '../../data/contact-copy';
import {
  contactFormAjaxUrl,
  contactFormNext,
  contactFormSubject,
  atelierContactPath,
  isContactFormReady,
} from '../../data/contact-config';
import AtelierTopbar from './AtelierTopbar.astro';

interface Props {
  lang: AtelierLang;
  copy: ContactCopy;
  sent: boolean;
}

const { lang, copy, sent } = Astro.props;
const formReady = isContactFormReady();
const ajaxUrl = contactFormAjaxUrl();
const nextUrl = contactFormNext(lang);
const subject = contactFormSubject(lang);
const homeCopy = atelierHomeCopy[lang];
const homePath = `/eliora/atelier/${lang}/`;
const nav = [
  ...homeCopy.nav.filter((item) => !item.href.includes('/contact/')),
  { href: atelierContactPath(lang), label: lang === 'ja' ? 'お問い合わせ' : lang === 'zh' ? '联系' : 'Contact' },
];
---

<div class="wrap">
  <AtelierTopbar
    lang={lang}
    brandSubtitle={copy.brandSubtitle}
    nav={nav}
    regionTags={homeCopy.regionTags}
    activeNav={atelierContactPath(lang)}
  />

  <main class="contact-page">
    {
      sent ? (
        <section class="block contact-success-panel" aria-live="polite">
          <span class="badge">{copy.badge}</span>
          <h1 class="section-title">{copy.successTitle}</h1>
          <p class="contact-lead">{copy.successLead}</p>
          <ul class="contact-success-list">
            {copy.successPoints.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
          <a class="btn btn-secondary" href={homePath} style="margin-top:20px">
            {copy.backHome}
          </a>
        </section>
      ) : (
        <section class="block contact-section">
          <span class="badge">{copy.badge}</span>
          <h1 class="section-title">{copy.title}</h1>
          <p class="contact-lead">{copy.lead}</p>
          <p class="contact-note">{copy.note}</p>

          {
            !formReady && copy.formNotReady ? (
              <p class="contact-note contact-form-pending">{copy.formNotReady}</p>
            ) : (
              <>
                <form class="contact-form" id="contact-form" method="post" accept-charset="UTF-8">
                  <input type="hidden" name="_subject" value={subject} />
                  <input type="hidden" name="_template" value="table" />
                  <input type="hidden" name="_autoresponse" value={copy.autoresponse} />
                  <input type="hidden" name="locale" value={lang} />
                  <input
                    type="text"
                    name="_honey"
                    class="contact-honey"
                    tabindex="-1"
                    autocomplete="off"
                    aria-hidden="true"
                  />

                  <div class="form-row">
                    <label for="contact-name">
                      {copy.fields.name}
                      <span class="form-required">{copy.fields.required}</span>
                    </label>
                    <input
                      id="contact-name"
                      type="text"
                      name="name"
                      required
                      minlength="1"
                      maxlength="120"
                      placeholder={copy.fields.namePlaceholder}
                      autocomplete="name"
                    />
                  </div>

                  <div class="form-row">
                    <label for="contact-email">
                      {copy.fields.email}
                      <span class="form-required">{copy.fields.required}</span>
                    </label>
                    <input
                      id="contact-email"
                      type="email"
                      name="email"
                      required
                      maxlength="254"
                      placeholder={copy.fields.emailPlaceholder}
                      autocomplete="email"
                    />
                  </div>

                  <div class="form-row">
                    <label for="contact-company">{copy.fields.company}</label>
                    <input
                      id="contact-company"
                      type="text"
                      name="company"
                      maxlength="160"
                      placeholder={copy.fields.companyPlaceholder}
                      autocomplete="organization"
                    />
                  </div>

                  <div class="form-row">
                    <label for="contact-type">
                      {copy.fields.inquiryType}
                      <span class="form-required">{copy.fields.required}</span>
                    </label>
                    <select id="contact-type" name="inquiry_type" required>
                      {
                        copy.inquiryTypes.map((opt) => (
                          <option value={opt.value}>{opt.label}</option>
                        ))
                      }
                    </select>
                  </div>

                  <div class="form-row">
                    <label for="contact-message">
                      {copy.fields.message}
                      <span class="form-required">{copy.fields.required}</span>
                    </label>
                    <textarea
                      id="contact-message"
                      name="message"
                      required
                      minlength="20"
                      maxlength="4000"
                      rows="8"
                      placeholder={copy.fields.messagePlaceholder}
                    />
                  </div>

                  <p class="form-privacy">{copy.privacy}</p>
                  <p class="form-autoreply-hint">{copy.formAutoreplyHint}</p>

                  <button type="submit" class="btn btn-primary contact-submit" data-submit-label={copy.fields.submit}>
                    {copy.fields.submit}
                  </button>
                </form>
                <script
                  is:inline
                  define:vars={{
                    ajaxUrl,
                    nextUrl,
                    submitLabel: copy.fields.submit,
                    submittingLabel: copy.fields.submitting,
                    submitError: copy.fields.submitError,
                    networkError: copy.fields.networkError,
                  }}
                >
                  (function () {
                    var form = document.getElementById('contact-form');
                    if (!form || !ajaxUrl) return;

                    form.addEventListener('submit', function (e) {
                      e.preventDefault();
                      if (!form.reportValidity()) return;

                      var btn = form.querySelector('button[type="submit"]');
                      var honey = form.querySelector('input[name="_honey"]');
                      if (honey && honey.value) return;

                      if (btn) {
                        btn.disabled = true;
                        btn.textContent = submittingLabel;
                      }

                      var payload = {};
                      new FormData(form).forEach(function (value, key) {
                        payload[key] = value;
                      });

                      fetch(ajaxUrl, {
                        method: 'POST',
                        headers: {
                          'Content-Type': 'application/json',
                          Accept: 'application/json',
                        },
                        body: JSON.stringify(payload),
                      })
                        .then(function (res) {
                          if (!res.ok) throw new Error('submit failed');
                          window.location.href = nextUrl;
                        })
                        .catch(function () {
                          alert(networkError + '\n' + submitError);
                          if (btn) {
                            btn.disabled = false;
                            btn.textContent = submitLabel;
                          }
                        });
                    });
                  })();
                </script>
              </>
            )
          }
        </section>
      )
    }
  </main>
</div>